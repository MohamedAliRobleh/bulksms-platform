# ─── Ces variables sont à configurer dans Railway ───────────

NODE_ENV=production
PORT=5000

# Database (Railway fournit cette variable automatiquement)
DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT (générez un secret fort)
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire
JWT_EXPIRES_IN=7d

# Frontend (URL Vercel, plusieurs URLs séparées par virgule)
CLIENT_URL=https://votre-app.vercel.app,https://votre-domaine.com

# Infobip SMS API
INFOBIP_API_KEY=votre_cle_api_infobip
INFOBIP_BASE_URL=https://XXXX.api.infobip.com
INFOBIP_DEFAULT_SENDER=BulkSMS

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_app_password
EMAIL_FROM=noreply@bulksms.dj
EMAIL_FROM_NAME=BulkSMS Platform

# Waafi Pay
WAAFI_API_URL=https://api.waafipay.net/asm
WAAFI_MERCHANT_UID=votre_merchant_uid
WAAFI_API_USER_ID=votre_api_user_id
WAAFI_API_KEY=votre_api_key
WAAFI_TEST_MODE=false

# Alertes
LOW_BALANCE_THRESHOLD=100
